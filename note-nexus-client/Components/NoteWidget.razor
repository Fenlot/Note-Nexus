@using note_nexus_client.Models
@using note_nexus_client.Services
@inject NoteService NoteApi 
@inject AppState AppState
@implements IDisposable

<div class="nn-card-header">
    <div class="nn-card-title">
        <div class="nn-card-icon notes">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="#fbbf24" stroke-width="1.5"><path d="M4 2h8a1 1 0 011 1v10a1 1 0 01-1 1H4a1 1 0 01-1-1V3a1 1 0 011-1z"/><path d="M5 5.5h6M5 8h4"/></svg>
        </div>
        Notepad
    </div>
</div>

<textarea class="nn-textarea" @bind="currentContent" placeholder="Start writing... ideas, quotes, anything that matters."></textarea>

<div class="nn-note-actions">
    <div class="nn-tag-row">
        <div class="nn-note-tag"># idea</div>
        <div class="nn-note-tag"># work</div>
        <div class="nn-note-tag">+ tag</div>
    </div>
    <div style="display:flex; gap:8px; align-items:center;">
        @if (editingId != null)
        {
            <button style="background:rgba(239,68,68,0.12); border:0.5px solid rgba(239,68,68,0.25); border-radius:8px; padding:7px 14px; font-size:12px; font-weight:500; color:#f87171; font-family:'DM Sans',sans-serif; cursor:pointer;"
                    @onclick="DeleteCurrentNote">
                Delete
            </button>
        }
        <button class="nn-btn-save" @onclick="SaveNote">Save note</button>
    </div>
</div>

<div style="border-top:0.5px solid rgba(255,255,255,0.06); padding-top:12px;">
    <div style="font-size:10px; color:rgba(255,255,255,0.2); letter-spacing:0.8px; text-transform:uppercase; margin-bottom:8px;">Recent</div>
    <div class="nn-saved-notes">
        @if (notes == null)
        {
            <div style="color:rgba(255,255,255,0.3); font-size:12px;">Loading...</div>
        }
        else if (notes.Count == 0)
        {
            <div style="color:rgba(255,255,255,0.2); font-size:12px;">No notes yet. Start writing!</div>
        }
        else
        {
            @foreach (var n in notes.Take(5))
            {
                <div class="nn-note-pill" @onclick="() => LoadNoteIntoEditor(n)" style="cursor:pointer;">
                    <div class="nn-note-pill-dot" style="background:@(editingId == n.Id ? "#a78bfa" : "#fbbf24");"></div>
                    <span class="nn-note-pill-text">@(string.IsNullOrWhiteSpace(n.Title) ? "Untitled" : n.Title)</span>
                    <span class="nn-note-pill-time">@GetTimeAgo(n.UpdatedAt)</span>
                </div>
            }
        }
    </div>
</div>

@code {
    private List<Note>? notes;
    private string currentContent = "";
    private long? editingId = null; 

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        AppState.OnChange += async () => { await LoadData(); StateHasChanged(); };
        await LoadData();
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private async Task LoadData() 
    {
        if (AppState.ActiveWorkspaceId == 0) return;
        notes = await NoteApi.GetNotesAsync();
    }

    private async Task SaveNote()
    {
        if (string.IsNullOrWhiteSpace(currentContent)) return;
        
        if (editingId == null) await NoteApi.CreateNoteAsync(currentContent);
        else await NoteApi.UpdateNoteAsync(editingId.Value, currentContent);

        ResetEditor();
        await LoadData();
    }

    private async Task DeleteCurrentNote()
    {
        if (editingId == null) return;
        await NoteApi.DeleteNoteAsync(editingId.Value);
        ResetEditor();
        await LoadData();
    }

    private void LoadNoteIntoEditor(Note n)
    {
        currentContent = n.Content;
        editingId = n.Id;
    }

    private void ResetEditor()
    {
        currentContent = "";
        editingId = null;
    }

    private string GetTimeAgo(DateTime? updatedAt)
    {
        if (updatedAt == null) return "";
        var diff = DateTime.UtcNow - updatedAt.Value;
        if (diff.TotalMinutes < 1) return "Just now";
        if (diff.TotalHours < 1) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalDays < 1) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 2) return "Yesterday";
        return $"{(int)diff.TotalDays}d ago";
    }
}