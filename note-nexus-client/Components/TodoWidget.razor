@using note_nexus_client.Models
@using note_nexus_client.Services
@inject TodoService TodoApi 
@inject AppState AppState
@implements IDisposable

<div class="nn-card-header">
    <div class="nn-card-title">
        <div class="nn-card-icon todo">
            <svg width="13" height="13" viewBox="0 0 16 16" fill="none" stroke="#a78bfa" stroke-width="1.5"><path d="M3 8l3 3 7-7"/></svg>
        </div>
        Todo List
    </div>
    <span style="font-size:11px; color:rgba(255,255,255,0.25);">@GetRemainingCount() remaining</span>
</div>

<div class="nn-add-row">
    <input class="nn-input" @bind="newTaskTitle" @onkeydown="@EnterKeyCheck" placeholder="Add a new task..." />
    <button class="nn-btn-primary" @onclick="HandleAdd">Add</button>
</div>

<div class="nn-task-list">
    @if (tasks == null)
    {
        <div style="color:rgba(255,255,255,0.3); font-size:13px; padding:10px;">Loading...</div>
    }
    else
    {
        @foreach (var task in tasks)
        {
            <div class="nn-task @(task.IsCompleted ? "done" : "")" @onclick="() => HandleToggle(task)">
                <div class="nn-checkbox">
                    @if (task.IsCompleted)
                    {
                        <div class="nn-check-mark"></div>
                    }
                </div>
                @if (editingTaskId == task.Id)
                {
                    <input class="nn-input" style="flex:1;" @bind="editingTitle" @onblur="CancelEdit" @onkeydown="@(e => EditKeyCheck(e, task.Id))" />
                }
                else
                {
                    <span class="nn-task-text" @ondblclick="() => StartEdit(task)" @onclick:stopPropagation="true">
                        @task.Title
                    </span>
                }
                <span class="nn-task-tag @GetPriorityClass(task)">@GetPriorityLabel(task)</span>
                <button style="background:none; border:none; color:rgba(255,255,255,0.15); cursor:pointer; font-size:12px; padding:4px;" 
                        @onclick="() => HandleDelete(task.Id)" @onclick:stopPropagation="true" title="Delete">
                    <svg width="12" height="12" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 5h10M5 5V3h6v2M6 7v5M10 7v5"/></svg>
                </button>
            </div>
        }
    }
</div>

@code {
    private List<TodoTask>? tasks;
    private string newTaskTitle = "";
    private long? editingTaskId = null;
    private string editingTitle = "";

    protected override async Task OnInitializedAsync()
    {
        AppState.OnChange += StateHasChanged;
        AppState.OnChange += async () => { await LoadData(); StateHasChanged(); };
        await LoadData();
    }

    public void Dispose()
    {
        AppState.OnChange -= StateHasChanged;
    }

    private int GetRemainingCount() => tasks?.Count(t => !t.IsCompleted) ?? 0;

    private string GetPriorityClass(TodoTask task)
    {
        if (task.IsCompleted) return "nn-tag-low";
        return "nn-tag-mid";
    }

    private string GetPriorityLabel(TodoTask task)
    {
        if (task.IsCompleted) return "done";
        return "pending";
    }

    private async Task LoadData() 
    {
        if (AppState.ActiveWorkspaceId == 0) return;
        tasks = await TodoApi.GetTasksAsync();
    }
    private async Task HandleAdd() { if (!string.IsNullOrWhiteSpace(newTaskTitle)) { await TodoApi.AddTaskAsync(newTaskTitle); newTaskTitle = ""; await LoadData(); } }
    private async Task HandleDelete(long id) { await TodoApi.DeleteTaskAsync(id); await LoadData(); }
    private async Task HandleToggle(TodoTask task) { task.IsCompleted = !task.IsCompleted; await TodoApi.ToggleTaskAsync(task.Id); }
    private void StartEdit(TodoTask task) { editingTaskId = task.Id; editingTitle = task.Title; }
    private void CancelEdit() => editingTaskId = null;
    private async Task SaveEdit(long id) { if (!string.IsNullOrWhiteSpace(editingTitle)) { await TodoApi.UpdateTaskTitleAsync(id, editingTitle); editingTaskId = null; await LoadData(); } }
    private async Task EnterKeyCheck(KeyboardEventArgs e) { if (e.Key == "Enter") await HandleAdd(); }
    private async Task EditKeyCheck(KeyboardEventArgs e, long id) { if (e.Key == "Enter") await SaveEdit(id); if (e.Key == "Escape") CancelEdit(); }
}