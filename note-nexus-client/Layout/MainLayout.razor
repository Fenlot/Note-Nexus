@inherits LayoutComponentBase
@using note_nexus_client.Components
@using note_nexus_client.Services
@using note_nexus_client.Models
@inject AuthService AuthService
@inject WorkspaceService WorkspaceService
@inject AppState AppState
@inject NavigationManager NavigationManager

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-bar">
            <div class="breadcrumbs">
                <SectionOutlet SectionName="Breadcrumbs" />
            </div>
            
            <AuthorizeView>
                <Authorized>
                    <div class="d-flex align-items-center gap-3">
                        <select class="form-select form-select-sm" @onchange="OnWorkspaceChanged">
                            @foreach (var workspace in workspaces)
                            {
                                <option value="@workspace.Id" selected="@(workspace.Id == AppState.ActiveWorkspaceId)">@workspace.Name</option>
                            }
                        </select>
                        
                        <ThemeToggle />
                        
                        <button class="btn btn-outline-danger btn-sm" @onclick="Logout">Logout</button>
                    </div>
                </Authorized>
                <NotAuthorized>
                    <ThemeToggle />
                </NotAuthorized>
            </AuthorizeView>
        </div>

        <div class="content px-4">
            @Body
        </div>
    </main>
</div>

@code {
    private List<Workspace> workspaces = new();

    protected override async Task OnInitializedAsync()
    {
        // Try to fetch workspaces if user is authenticated
        try
        {
            workspaces = await WorkspaceService.GetWorkspacesAsync();
            if (workspaces.Count > 0 && AppState.ActiveWorkspaceId == 0)
            {
                AppState.SetActiveWorkspace(workspaces[0].Id);
            }
        }
        catch
        {
            // Ignore errors if not authenticated
        }
    }

    private void OnWorkspaceChanged(ChangeEventArgs e)
    {
        if (long.TryParse(e.Value?.ToString(), out long newWorkspaceId))
        {
            AppState.SetActiveWorkspace(newWorkspaceId);
        }
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        NavigationManager.NavigateTo("/login");
    }
}

<style>
    .top-bar {
        display: flex; 
        justify-content: space-between; 
        align-items: center;
        padding: 10px 20px;
        background: transparent;
        margin-bottom: 10px;
    }
    
    .breadcrumbs {
        color: #999;
        font-size: 0.9rem;
        font-weight: 500;
    }
</style>