<div class="top-row navbar navbar-dark">
    <a class="navbar-brand logo-container text-decoration-none" href="">
        <div class="brand-composite brand-sidebar">
            <img src="images/notenexus_icon_only.svg" alt="NoteNexus Logo" class="brand-composite-img" />
            <div class="brand-composite-text-block">
                <div class="brand-composite-title">NoteNexus</div>
            </div>
        </div>
    </a>

    <button title="Navigation menu"
            class="navbar-toggler"
            @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="CloseNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="bi bi-house-door-fill" aria-hidden="true"></span> Home
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="todos">
                <span class="bi bi-check-square-fill" aria-hidden="true"></span> Todo List
            </NavLink>
        </div>

        <div class="nav-item px-3">
            <NavLink class="nav-link" href="notepad">
                <span class="bi bi-journal-text" aria-hidden="true"></span> Notepad
            </NavLink>
        </div>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void CloseNavMenu()
    {
        if (!collapseNavMenu)
        {
            collapseNavMenu = true;
        }
    }
}