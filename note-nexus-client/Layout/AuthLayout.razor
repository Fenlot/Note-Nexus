@inherits LayoutComponentBase

<div class="nn-auth-root">
    <div class="nn-glow nn-glow-purple"></div>
    <div class="nn-glow nn-glow-blue"></div>

    <div class="nn-auth-header">
        <div class="nn-logo-mark" style="font-size:18px; gap:8px;">
            <span class="nn-logo-dot"></span> NoteNexus
        </div>
    </div>

    <main class="nn-auth-main">
        @Body
    </main>
</div>

<style>
    .nn-auth-root {
        display: flex;
        flex-direction: column;
        min-height: 100vh;
        background: #0d0d0f;
        font-family: 'DM Sans', sans-serif;
        position: relative;
        overflow: hidden;
    }

    .nn-auth-header {
        display: flex;
        align-items: center;
        padding: 24px 32px;
    }

    .nn-auth-main {
        flex: 1;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 2rem;
    }
</style>
